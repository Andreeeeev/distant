@model distant.Models.HomeViewModel

@{
    ViewData["Title"] = "Главная";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    @if (!User.Identity.IsAuthenticated)
    {
        <div class="text-center mt-5">
            <h1 class="display-4">Добро пожаловать!</h1>
            <p class="fs-5 text-muted">Пожалуйста, войдите в систему, чтобы увидеть свой прогресс.</p>
        </div>
    }
    else
    {
        <h2 class="mb-4">👋 Здравствуйте!</h2>
        <p class="fs-5 text-muted">Вы успешно завершили <strong>@Model.CompletedCourses.Count</strong> курсов.</p>
        <hr class="mb-5" />

        <div class="row">
            <div class="col-md-6 mb-4">
                <h4 class="mb-3" style="color: var(--color-dark-blue);"> Ваши достижения</h4>
                @if (Model.CompletedCourses.Any())
                {
                    <ul class="list-group shadow-sm">
                        @foreach (var cr in Model.CompletedCourses)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                                <span class="fs-5">@cr.Course.Name</span>
                                <span class="badge rounded-pill fs-6" style="background-color: var(--color-pink);">Оценка: @cr.FinalGrade</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="alert alert-light border">У вас пока нет завершенных курсов.</div>
                }
            </div>

            <div class="col-md-6 mb-4">
                <h4 class="mb-3" style="color: var(--color-dark-blue);"> В процессе изучения</h4>
                @if (Model.ActiveCourses.Any())
                {
                    <div class="accordion shadow-sm" id="activeCoursesAccordion">
                        @foreach (var active in Model.ActiveCourses)
                        {
                            <div class="accordion-item">
                                <h2 class="accordion-header">
                                    <button class="accordion-button collapsed fs-5" type="button" data-bs-toggle="collapse" data-bs-target="#course_@active.Course.Id">
                                        @active.Course.Name
                                        <span class="badge bg-secondary ms-2">Осталось тестов: @active.RemainingTests.Count</span>
                                    </button>
                                </h2>
                                <div id="course_@active.Course.Id" class="accordion-collapse collapse" data-bs-parent="#activeCoursesAccordion">
                                    <div class="accordion-body">
                                        @if (active.RemainingTests.Any())
                                        {
                                            <ul class="mb-3">
                                                @foreach (var test in active.RemainingTests)
                                                {
                                                    <li>@test.Title</li>
                                                }
                                            </ul>
                                        }
                                        else
                                        {
                                            <p class="text-success">Все тесты сданы!</p>
                                        }
                                        <a asp-controller="Course" asp-action="Details" asp-route-id="@active.Course.Id" class="btn btn-sm btn-outline-primary">Перейти к курсу</a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>